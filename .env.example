# Database (required for assets, users, settings)
# SQLite file path - use a path relative to project root or absolute
DATABASE_URL="file:./prisma/dev.db"

# Optional: Gemini AI assistant (leave unset to disable the AI assistant)
# API_KEY="your-google-ai-studio-api-key"

# For cPanel production: use DATABASE_URL="file:./prisma/production.db"
