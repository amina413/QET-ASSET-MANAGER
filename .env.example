# Database
DATABASE_URL="postgresql://user:password@localhost:5432/qet_asset_manager"

# Session (must be at least 32 characters, random string)
SESSION_SECRET="change-this-to-a-random-32-plus-character-secret"

# AI Assistant (optional)
GEMINI_API_KEY="your_gemini_api_key_here"

# Asset image object storage (S3-compatible; required for browser image uploads)
ASSET_IMAGE_S3_BUCKET="qet-asset-images"
ASSET_IMAGE_S3_REGION="eu-west-1"
ASSET_IMAGE_S3_ENDPOINT="https://account-id.r2.cloudflarestorage.com"
ASSET_IMAGE_S3_FORCE_PATH_STYLE="true"
ASSET_IMAGE_S3_ACCESS_KEY_ID="your_access_key"
ASSET_IMAGE_S3_SECRET_ACCESS_KEY="your_secret_key"
ASSET_IMAGE_PUBLIC_BASE_URL="https://assets.example.com"
REQUIRE_ASSET_IMAGES="false"

# Distributed rate limiting / login lockout (recommended for production)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"
REQUIRE_DISTRIBUTED_RATE_LIMITS="false"
TRUST_PROXY="true"

# Internal readiness probe token
HEALTH_CHECK_TOKEN="change-this-health-token"

# Feature flags
NEXT_PUBLIC_ENABLE_WIP="false"

# Seed passwords (optional)
SEED_DEFAULT_PASSWORD="ChangeMe123!"
SEED_OKALU_PASSWORD="ChangeMe123!"
ALLOW_PROD_SEED="false"
ALLOW_ASSET_CLEAR="false"

# Node environment
NODE_ENV="development"
