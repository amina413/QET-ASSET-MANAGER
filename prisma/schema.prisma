generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String         @id @default(cuid())
  name       String
  email      String         @unique
  password   String         @default("$2a$10$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX")
  department String
  role       Role           @default(CUSTODIAN)
  lastLogin  DateTime       @default(now())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  assets     Asset[]        @relation("AssetCustodian")
  history    AssetHistory[]
}

model Asset {
  id               String                 @id @default(cuid())
  productId        String                 @unique
  name             String
  category         String
  subCategory      String?
  acquisitionCost  Decimal
  acquisitionDate  DateTime
  salvageValue     Decimal                @default(0)
  usefulLife       Int
  method           DepreciationMethod     @default(STRAIGHT_LINE)
  location         String
  subLocation      String?
  status           AssetStatus            @default(ACTIVE)
  conditionCode    String?
  image            String?
  registrationDate DateTime               @default(now())
  custodianId      String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  custodian        User                   @relation("AssetCustodian", fields: [custodianId], references: [id])
  history          AssetHistory[]
  improvements     AssetImprovement[]
  schedules        DepreciationSchedule[]
  transferRequests TransferRequest[]
}

model DepreciationSchedule {
  id                  String   @id @default(cuid())
  assetId             String
  year                Int
  fiscalYear          Int
  depreciationExpense Decimal
  accumulatedDepr     Decimal
  netBookValue        Decimal
  createdAt           DateTime @default(now())
  asset               Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model TransferRequest {
  id            String    @id @default(cuid())
  assetId       String
  fromLocation  String
  toLocation    String
  toCustodian   String
  toCustodianId String?
  requestedById String
  approvedById  String?
  status        String    @default("PENDING")
  requestedAt   DateTime  @default(now())
  resolvedAt    DateTime?
  notes         String?
  asset         Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetHistory {
  id           String   @id @default(cuid())
  assetId      String
  date         DateTime @default(now())
  action       String
  details      String
  type         String
  userId       String
  fromLocation String?
  toCustodian  String?
  toLocation   String?
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id])
}

model AssetImprovement {
  id                 String   @id @default(cuid())
  assetId            String
  date               DateTime @default(now())
  type               String
  amount             Decimal
  description        String
  newAcquisitionCost Decimal
  asset              Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  location  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Custodian {
  id         String   @id @default(cuid())
  name       String
  department String
  location   String
  email      String?
  phone      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id         String      @id @default(cuid())
  name       String      @unique
  code       String?
  sortOrder  Int         @default(0)
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  assetTypes AssetType[]
}

model AssetType {
  id         String   @id @default(cuid())
  categoryId String
  name       String
  code       String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model AssetClass {
  id               String            @id @default(cuid())
  name             String            @unique
  code             String?
  sortOrder        Int               @default(0)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  custodianOptions CustodianOption[]
}

model CustodianOption {
  id           String     @id @default(cuid())
  assetClassId String
  name         String
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assetClass   AssetClass @relation(fields: [assetClassId], references: [id], onDelete: Cascade)
}

enum Role {
  SYSTEM_ADMIN
  ASSET_MANAGER
  CUSTODIAN
  AUDITOR
}

enum AssetStatus {
  ACTIVE
  DISPOSED
  MAINTENANCE
  PENDING_TRANSFER
}

enum DepreciationMethod {
  STRAIGHT_LINE
  REDUCING_BALANCE
  SUM_OF_YEARS
}
