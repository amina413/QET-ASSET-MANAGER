generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String         @id @default(cuid())
  name       String
  email      String         @unique
  password   String
  department String
  role       Role           @default(CUSTODIAN)
  isActive   Boolean        @default(true)
  lastLogin  DateTime       @default(now())
  sessionVersion Int        @default(1)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  assets     Asset[]        @relation("AssetCustodian")
  history    AssetHistory[]
  requestedTransfers TransferRequest[] @relation("TransferRequestedBy")
  approvedTransfers  TransferRequest[] @relation("TransferApprovedBy")

  @@index([role])
  @@index([isActive])
}

model Asset {
  id               String                 @id @default(cuid())
  productId        String                 @unique
  name             String
  category         String
  subCategory      String?
  acquisitionCost  Decimal                @db.Decimal(18, 2)
  acquisitionDate  DateTime
  salvageValue     Decimal                @default(0) @db.Decimal(18, 2)
  usefulLife       Int
  method           DepreciationMethod     @default(STRAIGHT_LINE)
  location         String
  subLocation      String?
  status           AssetStatus            @default(ACTIVE)
  isActive         Boolean                @default(true)
  conditionCode    String?
  imageUrl         String?
  registrationDate DateTime               @default(now())
  custodianId      String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  custodian        User                   @relation("AssetCustodian", fields: [custodianId], references: [id])
  history          AssetHistory[]
  improvements     AssetImprovement[]
  schedules        DepreciationSchedule[]
  transferRequests TransferRequest[]

  @@index([category])
  @@index([location])
  @@index([status])
  @@index([isActive])
  @@index([custodianId])
  @@index([registrationDate])
}

model DepreciationSchedule {
  id                  String   @id @default(cuid())
  assetId             String
  year                Int
  fiscalYear          Int
  depreciationExpense Decimal  @db.Decimal(18, 2)
  accumulatedDepr     Decimal  @db.Decimal(18, 2)
  netBookValue        Decimal  @db.Decimal(18, 2)
  createdAt           DateTime @default(now())
  asset               Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, fiscalYear])
}

model TransferRequest {
  id            String         @id @default(cuid())
  assetId       String
  fromLocation  String
  toLocation    String
  toCustodian   String
  toCustodianId String
  requestedById String
  approvedById  String?
  status        TransferStatus @default(PENDING)
  requestedAt   DateTime       @default(now())
  resolvedAt    DateTime?
  notes         String?
  asset         Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  requestedBy   User           @relation("TransferRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  approvedBy    User?          @relation("TransferApprovedBy", fields: [approvedById], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([assetId])
  @@index([assetId, status])
  @@index([requestedById])
}

model AssetHistory {
  id           String       @id @default(cuid())
  assetId      String
  date         DateTime     @default(now())
  action       String
  details      String
  type         HistoryType
  userId       String
  fromLocation String?
  toCustodian  String?
  toLocation   String?
  asset        Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([assetId])
  @@index([userId])
}

model AssetImprovement {
  id                 String          @id @default(cuid())
  assetId            String
  date               DateTime        @default(now())
  type               ImprovementType
  amount             Decimal         @db.Decimal(18, 2)
  description        String
  newAcquisitionCost Decimal         @db.Decimal(18, 2)
  asset              Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  location  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Custodian {
  id         String   @id @default(cuid())
  name       String
  department String
  location   String
  email      String?
  phone      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id         String      @id @default(cuid())
  name       String      @unique
  code       String?
  sortOrder  Int         @default(0)
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  assetTypes AssetType[]
}

model AssetType {
  id         String   @id @default(cuid())
  categoryId String
  name       String
  code       String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

model AssetClass {
  id               String            @id @default(cuid())
  name             String            @unique
  code             String?
  sortOrder        Int               @default(0)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  custodianOptions CustodianOption[]
}

model CustodianOption {
  id           String     @id @default(cuid())
  assetClassId String
  name         String
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assetClass   AssetClass @relation(fields: [assetClassId], references: [id], onDelete: Cascade)

  @@index([assetClassId])
}

enum Role {
  SYSTEM_ADMIN
  ASSET_MANAGER
  CUSTODIAN
  AUDITOR
}

enum AssetStatus {
  ACTIVE
  DISPOSED
  MAINTENANCE
  PENDING_TRANSFER
}

enum DepreciationMethod {
  STRAIGHT_LINE
  REDUCING_BALANCE
  SUM_OF_YEARS
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HistoryType {
  Registration
  Transfer
  Maintenance
  Audit
  Issue
  Update
}

enum ImprovementType {
  Addition
  Reduction
  Revaluation
}
